generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  VAN
  TRUCK
  MINI
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintStatus {
  ACTIVE
  COMPLETED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver        Driver?
  tripsCreated  Trip[]   @relation("TripCreatedBy")
}

model Vehicle {
  id               String        @id @default(uuid())
  regNumber        String        @unique
  name             String
  type             VehicleType
  maxLoadKg        Float
  odometer         Float
  acquisitionCost  Float
  status           VehicleStatus @default(AVAILABLE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]

  @@index([regNumber])
}

model Driver {
  id               String       @id @default(uuid())
  userId           String?      @unique
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  licenseNumber    String       @unique
  licenseCategory  String
  licenseExpiry    DateTime
  contact          String
  safetyScore      Int          @default(100)
  status           DriverStatus @default(AVAILABLE)
  updatedAt        DateTime     @updatedAt

  trips            Trip[]

  @@index([licenseNumber])
  @@index([licenseExpiry])
}

model Trip {
  id                  String     @id @default(uuid())
  createdById         String
  createdBy           User       @relation("TripCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  source              String
  destination         String
  vehicleId           String
  vehicle             Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driverId            String
  driver              Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  cargoWeightKg       Float
  plannedDistanceKm   Float
  actualDistanceKm    Float?
  fuelConsumedL       Float?
  status              TripStatus @default(DRAFT)
  dispatchedAt        DateTime?
  completedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  fuelLogs            FuelLog[]
  expenses            Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id           String      @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceType  String
  cost         Float
  date         DateTime
  status       MaintStatus @default(ACTIVE)
  updatedAt    DateTime    @updatedAt
}

model FuelLog {
  id         String    @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId     String?
  trip       Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
  liters     Float
  cost       Float
  date       DateTime
  updatedAt  DateTime @updatedAt
}

model Expense {
  id         String    @id @default(uuid())
  vehicleId  String?
  vehicle    Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId     String?
  trip       Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
  type       String
  amount     Float
  date       DateTime
  updatedAt  DateTime @updatedAt
}